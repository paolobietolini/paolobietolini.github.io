order_reconciliation:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: service-account
      project: "{{ env_var('GCP_PROJECT', 'zmcp-final') }}"
      dataset: "{{ env_var('BQ_DATASET', 'reconciliation') }}"
      location: US
      keyfile: "{{ env_var('GOOGLE_APPLICATION_CREDENTIALS') }}"
      threads: 4
    ci:
      type: bigquery
      method: oauth
      project: "{{ env_var('GCP_PROJECT', 'zmcp-final') }}"
      dataset: "{{ env_var('BQ_DATASET', 'reconciliation') }}"
      location: US
      threads: 1
